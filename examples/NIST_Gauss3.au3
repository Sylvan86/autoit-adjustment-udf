#AutoIt3Wrapper_Change2CUI=y

; ===============================================================================
;   Gauss3 — NIST Nonlinear Regression, Higher Difficulty
; ===============================================================================
;
; Source:
;   NIST/ITL Statistical Reference Datasets (StRD) for Nonlinear Least Squares.
;   Dataset: Gauss3.
;   URL: https://www.itl.nist.gov/div898/strd/nls/data/gauss3.shtml
;   Original: Rust, B., NIST (1996).
;
; Problem:
;   Two Gaussians on exponential background (generated data).
;   Mixed exponential-Gaussian model with 8 parameters:
;     y = B1*Exp(-B2*x) + B3*Exp(-((x - B4)^2)/B5^2) + B6*Exp(-((x - B7)^2)/B8^2)
;   250 observations, 8 unknowns.
;
;   Classified as "Higher Difficulty" by NIST — large parameter space
;   and overlapping Gaussian peaks make convergence challenging.
;
; Classification:
;   Model:       Observation equations (Gauss-Markov), nonlinear
;   Weighting:   Unweighted (OLS)
;   Linearity:   Nonlinear
;   Algorithm:   Levenberg-Marquardt
;   VCE:         No
;   Redundancy:  f = n - u = 250 - 8 = 242
;
; ===============================================================================


; -- Initialization --------------------------------------------------------------
#include "../Adjustment.au3"


