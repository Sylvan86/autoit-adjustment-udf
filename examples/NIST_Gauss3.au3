;   b2 =     1.0945879335E-02    sd(b2) = 1.2554058911E-04
;   b3 =     1.0069553078E+02    sd(b3) = 8.1256587317E-01
;   b4 =     1.1163619459E+02    sd(b4) = 3.5317859757E-01
;   b5 =     2.3300500029E+01    sd(b5) = 3.6584783023E-01
;   b6 =     7.3705031418E+01    sd(b6) = 1.2091239082E+00
;   b7 =     1.4776164251E+02    sd(b7) = 4.0488183351E-01
;   b8 =     1.9668221230E+01    sd(b8) = 3.7806634336E-01
;   Residual SS = 1.2444846360E+03

Global $mRes = _adj_getResults($mSystem)
Global $mX1  = $mRes.x1
Global $mSdx = $mRes.sdx

ConsoleWrite(@CRLF)
ConsoleWrite("+===================================================+" & @CRLF)
ConsoleWrite("|  Validation vs. NIST Certified Values              |" & @CRLF)
ConsoleWrite("+===================================================+" & @CRLF & @CRLF)

; --- Adjusted parameters ---
ConsoleWrite("Adjusted parameters:" & @CRLF)
_check("b1", $mX1["B1"], 9.8940368970E+01, 4)
_check("b2", $mX1["B2"], 1.0945879335E-02, 7)
_check("b3", $mX1["B3"], 1.0069553078E+02, 3)
_check("b4", $mX1["B4"], 1.1163619459E+02, 3)
_check("b5", $mX1["B5"], 2.3300500029E+01, 4)
_check("b6", $mX1["B6"], 7.3705031418E+01, 4)
_check("b7", $mX1["B7"], 1.4776164251E+02, 3)
_check("b8", $mX1["B8"], 1.9668221230E+01, 4)

; --- Standard deviations ---
ConsoleWrite(@CRLF & "Standard deviations:" & @CRLF)
_check("sd(b1)", $mSdx["B1"], 5.3005192833E-01, 5)
_check("sd(b2)", $mSdx["B2"], 1.2554058911E-04, 8)
